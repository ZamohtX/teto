# ==========================================
# 🏠 TETO - VARIÁVEIS DE AMBIENTE LOCAIS
# ==========================================
# Instruções: Copie este arquivo, renomeie para ".env"
# e não o commite no repositório.

# --- BACKEND (Spring Boot / Banco de Dados) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teto_db
DB_USER=teto_user
DB_PASSWORD=teto_password

# Chave secreta para assinar os tokens JWT (Use uma string longa e aleatória no seu .env real)
JWT_SECRET=chave_secreta_super_segura_para_desenvolvimento_local

# Tempo de vida do Token
JWT_HOURS_LIFETIME=2

# Emissor do Token
JWT_ISSUER=teto-app

# --- FRONTEND (React Native / Expo) ---
# O prefixo EXPO_PUBLIC_ é obrigatório para o app enxergar a variável
EXPO_PUBLIC_API_URL=http://localhost:8080/api
